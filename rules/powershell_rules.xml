<group name="powershell_detection,sysmon,">

  <rule id="200100" level="7">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2" negate="yes">(?i)wazuh-agent\.exe$</field>
    <description>PowerShell launched by user: $(win.eventdata.user) | Parent: $(win.eventdata.parentImage)</description>
    <group>powershell_launch,t1059.001,</group>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <rule id="200101" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-enc|-encodedcommand|-nop|-noprofile|-windowstyle\s+hidden|-executionpolicy\s+bypass|-noninteractive</field>
    <description>PowerShell suspicious flags | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_evasion,t1059.001,</group>
    <mitre><id>T1059.001</id><id>T1027</id></mitre>
  </rule>

  <rule id="200102" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)DownloadString|DownloadFile|Invoke-WebRequest|Start-BitsTransfer|Net\.WebClient</field>
    <description>PowerShell download cradle | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_download,t1105,</group>
    <mitre><id>T1105</id><id>T1059.001</id></mitre>
  </rule>

  <rule id="200103" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Invoke-Expression|Invoke-Command|Reflection\.Assembly</field>
    <description>PowerShell in-memory execution | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_fileless,t1059.001,</group>
    <mitre><id>T1059.001</id><id>T1620</id></mitre>
  </rule>

  <rule id="200104" level="7">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)whoami|net\s+user|net\s+localgroup|Get-LocalUser|Get-LocalGroup|systeminfo|ipconfig|Get-Process|Get-Service</field>
    <description>PowerShell recon command | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_recon,t1082,</group>
    <mitre><id>T1082</id><id>T1059.001</id></mitre>
  </rule>

  <rule id="200105" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\winword\.exe$|\\excel\.exe$|\\powerpnt\.exe$|\\outlook\.exe$|\\chrome\.exe$|\\firefox\.exe$|\\wscript\.exe$|\\cscript\.exe$|\\mshta\.exe$|\\cmd\.exe$</field>
    <description>PowerShell suspicious parent: $(win.eventdata.parentImage) | User: $(win.eventdata.user)</description>
    <group>powershell_suspicious_parent,t1566,</group>
    <mitre><id>T1566.001</id><id>T1059.001</id></mitre>
  </rule>

  <rule id="200106" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)mimikatz|Invoke-Mimikatz|lsass|sekurlsa|SAMDump</field>
    <description>CRITICAL: PowerShell credential theft | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_credtheft,t1003,</group>
    <mitre><id>T1003</id><id>T1059.001</id></mitre>
  </rule>

  <rule id="200107" level="9">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Register-ScheduledTask|New-ScheduledTask|Add-MpPreference|New-Service</field>
    <description>PowerShell persistence detected | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_persistence,t1053,</group>
    <mitre><id>T1053.005</id><id>T1059.001</id></mitre>
  </rule>

  <rule id="200108" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)Clear-EventLog|Remove-EventLog|DisableRealtimeMonitoring|DisableIOAVProtection|wevtutil</field>
    <description>CRITICAL: PowerShell defense evasion | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_defense_evasion,t1562,</group>
    <mitre><id>T1562.001</id><id>T1070.001</id></mitre>
  </rule>

 <rule id="200109" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)MiniDumpWriteDump|Out-Minidump|comsvcs\.dll.*MiniDump|Stop-Process.*-Force</field>
    <description>CRITICAL: PowerShell memory dump or aggressive process kill | User: $(win.eventdata.user) | CMD: $(win.eventdata.commandLine)</description>
    <group>powershell_memory_abuse,t1003.001,t1489,</group>
    <mitre>
      <id>T1003.001</id>
      <id>T1489</id>
    </mitre>
  </rule>

</group>
